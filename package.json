{
    "name": "valdres-monorepo",
    "type": "module",
    "private": true,
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "scripts": {
        "build": "bun --filter '*' build",
        "build_old": "bun run lerna run build",
        "build:types": "bun run lerna run build:types",
        "publish_old": "bun run lerna publish  --force-publish",
        "test_old": "bun run lerna run test",
        "dev": "bun run lerna run build --parallel -- --watch",
        "bump": "bun ./scripts/bump.tsx",
        "publish": "bun scripts/publish.tsx",
        "test": "bun --filter '*' test",
        "test:ci": "bun --filter '*' test -- --reporter=junit --reporter-outfile=junit.xml",
        "docs:build": "bun run docs/build.ts",
        "docs:dev": "bun run docs/dev.ts"
    },
    "workspaces": [
        "packages/*",
        "packages/@valdres/*",
        "packages/@valdres-react/*"
    ],
    "engines": {
        "bun": ">=1.3.13"
    },
    "devDependencies": {
        "@mdx-js/mdx": "^3.1.1",
        "@shikijs/rehype": "^4.0.2",
        "@tailwindcss/cli": "^4.2.2",
        "@tailwindcss/typography": "^0.5.19",
        "@types/bun": "1.2.2",
        "@types/react": "19.2.3",
        "@types/react-dom": "^19.2.3",
        "@types/topojson-client": "^3.1.5",
        "clsx": "^2.1.1",
        "eslint": "9.20.1",
        "eslint-config-prettier": "10.0.1",
        "gray-matter": "^4.0.3",
        "ink": "6.2.3",
        "ink-select-input": "6.2.0",
        "ink-spinner": "5.0.0",
        "lerna": "8.1.9",
        "pagefind": "^1.5.0",
        "prettier": "3.5.3",
        "react": "19.2.5",
        "react-dom": "^19.2.5",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-slug": "^6.0.0",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "remark-mdx-frontmatter": "^5.2.0",
        "semver": "7.7.1",
        "shiki": "^4.0.2",
        "solid-js": "^1.9.12",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "topojson-client": "^3.1.0"
    },
    "version": "0.2.0-pre.28",
    "dependencies": {
        "camera-controls": "^3.1.2",
        "globe.gl": "^2.45.3"
    }
}