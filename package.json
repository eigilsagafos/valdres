{
    "name": "valdres-monorepo",
    "type": "module",
    "private": true,
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "scripts": {
        "build": "bun --filter '*' build",
        "build:types": "bun --filter '*' build:types",
        "test": "bun --filter '*' test",
        "test:ci": "bun --filter '*' test -- --reporter=junit --reporter-outfile=junit.xml",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "bash scripts/ci-publish.sh",
        "verify-publish": "bun run scripts/verify-publish.ts"
    },
    "workspaces": [
        "packages/*",
        "packages/@valdres/*",
        "packages/@valdres-react/*"
    ],
    "engines": {
        "bun": ">=1.3.13"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.6.0",
        "@changesets/cli": "^2.30.0",
        "@types/bun": "1.2.2",
        "@typescript/native-preview": "^7.0.0-dev.20260521.1",
        "eslint": "9.20.1",
        "eslint-config-prettier": "10.0.1",
        "prettier": "3.5.3",
        "react": "19.1.1"
    },
    "version": "1.0.0-beta.0"
}
