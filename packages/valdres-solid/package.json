{
    "name": "valdres-solid",
    "description": "Solid.js bindings for Valdres state management",
    "version": "1.0.0-beta.4",
    "license": "MIT",
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "NODE_ENV=production bun build src/index.ts --outdir ./dist --packages external",
        "build:types": "rm -rf dist/types && bunx tsgo",
        "test": "bun test --parallel"
    },
    "devDependencies": {
        "typescript": "5.9.2",
        "valdres": "workspace:^",
        "solid-js": "1.9.5"
    },
    "peerDependencies": {
        "valdres": "^1.0.0-beta.7",
        "solid-js": ">=1.8"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
