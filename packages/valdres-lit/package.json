{
    "name": "valdres-lit",
    "version": "1.0.0-beta.4",
    "license": "MIT",
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": "./src/index.ts"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "NODE_ENV=production bun build src/index.ts --outdir ./dist --packages external",
        "build:types": "rm -rf dist/types && bunx tsgo",
        "test": "bun test --parallel",
        "dev": "PORT=3030 bun --hot dev/index.html"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.0.5",
        "happy-dom": "20.0.5",
        "lit": "3.2.1",
        "@lit/context": "1.1.4",
        "typescript": "5.9.2",
        "valdres": "workspace:^"
    },
    "peerDependencies": {
        "valdres": "^1.0.0-beta.7",
        "lit": ">=3",
        "@lit/context": ">=1"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
