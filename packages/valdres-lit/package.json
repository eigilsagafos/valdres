{
    "name": "valdres-lit",
    "version": "1.0.0-beta.4",
    "license": "MIT",
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./decorators": "./src/decorators/index.ts",
        "./decorators.js": "./src/decorators/index.ts",
        "./watch": "./src/watch/index.ts",
        "./watch.js": "./src/watch/index.ts",
        "./signals": "./src/signals/index.ts",
        "./signals.js": "./src/signals/index.ts"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rm -rf dist && NODE_ENV=production bun build src/index.ts src/decorators/index.ts src/watch/index.ts src/signals/index.ts --outdir ./dist --packages external --splitting",
        "build:types": "rm -rf dist/types && bunx tsgo",
        "test": "bun run test:decorators && bun test --parallel",
        "test:decorators": "rm -rf .decorators-test && bunx tsc -p tsconfig.decorators-test.json && bun .decorators-test/test/decorators-tsc/run.js",
        "dev": "PORT=3030 bun --hot dev/index.html"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.0.5",
        "@lit-labs/signals": "^0.3.0",
        "@lit/context": "1.1.4",
        "@lit/reactive-element": "^2.1.2",
        "happy-dom": "20.0.5",
        "lit": "3.2.1",
        "lit-html": "^3.3.3",
        "signal-polyfill": "^0.2.2",
        "typescript": "5.9.2",
        "valdres": "workspace:^"
    },
    "peerDependencies": {
        "valdres": "^1.0.0-beta.7",
        "lit": ">=3",
        "@lit/context": ">=1",
        "signal-polyfill": "^0.2.2"
    },
    "peerDependenciesMeta": {
        "signal-polyfill": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
