{
    "name": "valdres-svelte",
    "version": "0.1.0-beta.0",
    "license": "MIT",
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "svelte": "./src/index.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "NODE_ENV=production bun build src/index.ts --outdir ./dist --packages external",
        "build:types": "rm -rf dist/types && bunx tsgo",
        "test": "bun test --parallel src/"
    },
    "devDependencies": {
        "@valdres/test": "workspace:^",
        "svelte": "5.28.2",
        "typescript": "5.9.2",
        "valdres": "workspace:^"
    },
    "peerDependencies": {
        "svelte": ">=5",
        "valdres": "workspace:^"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
