{
    "name": "valdres-svelte",
    "description": "Svelte 5 bindings for Valdres state management",
    "version": "1.0.0-beta.4",
    "license": "MIT",
    "author": {
        "name": "Eigil Sagafos"
    },
    "homepage": "https://valdres.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eigilsagafos/valdres.git"
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "svelte-package --input src --output dist --tsconfig ./tsconfig.json && find dist \\( -name '*.test.*' -o -name '*.mdx' \\) -delete",
        "test": "bun test --conditions browser src/",
        "lint:publish": "publint --strict && svelte-check --workspace ./dist"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.0.5",
        "@sveltejs/package": "^2.5.8",
        "@valdres/test": "workspace:^",
        "publint": "^0.3.21",
        "svelte": "5.28.2",
        "svelte-check": "^4.6.0",
        "typescript": "5.9.2",
        "valdres": "workspace:^",
        "zod": "^4.3.6"
    },
    "peerDependencies": {
        "svelte": ">=5.7",
        "valdres": "^1.0.0-beta.7"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
